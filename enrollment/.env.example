# enrollment — copy to .env and fill in values

# Pipeline worker URL — enrollment ships audio here for embedding
# The pipeline worker computes embeddings using its configured SPEAKER_ENCODER
PIPELINE_URL=http://blackmagic.lan:8001

# memory-mcp HTTP API — used for --list and --unknown commands only
MEMORY_MCP_URL=http://memory-mcp.lan:8900
MEMORY_MCP_TOKEN=

# Default recording duration if --duration not specified
DEFAULT_RECORD_DURATION_S=10

# Audio device index for recording (leave blank to use system default)
# Run: python -c "import sounddevice; print(sounddevice.query_devices())"
DEVICE_INDEX=

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

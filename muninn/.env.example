# Muninn Memory Server — copy to .env and edit

# Database
MUNINN_DB_PATH=./data/muninn.db

# Service
MUNINN_PORT=8900
MUNINN_WORKERS=2

# Embedding — must match Verdandi's embed model
MUNINN_EMBED_MODEL=nomic-embed-text
MUNINN_EMBED_DIM=768

# Ollama (for embedding on write via MCP / search routes)
OLLAMA_URL=http://blackmagic.lan:11434

# TTL defaults
MUNINN_EPISODIC_TTL_DAYS=90
MUNINN_TIMESERIES_TTL_DAYS=180
MUNINN_FOLLOWUP_TTL_HOURS=4

# Logging
LOG_LEVEL=INFO

# Importers (optional)
OBSIDIAN_VAULT_PATH=/path/to/your/vault
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token
HA_CALENDAR_IDS=calendar.family,calendar.work
HA_CALENDAR_DAYS=14

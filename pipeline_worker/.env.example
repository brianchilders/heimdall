# pipeline_worker — copy to .env and fill in values

# memory-mcp HTTP API (memory-mcp.lan, port 8900)
MEMORY_MCP_URL=http://memory-mcp.lan:8900
MEMORY_MCP_TOKEN=

# Port this service listens on
PIPELINE_PORT=8001

# Local SQLite cache of voiceprint embeddings
# Rebuilt from memory-mcp on startup; updated after each confident match
VOICEPRINT_DB=./voiceprints.sqlite

# Voiceprint matching thresholds (cosine similarity, 0.0–1.0)
VOICEPRINT_CONFIDENT_THRESHOLD=0.85
VOICEPRINT_PROBABLE_THRESHOLD=0.70

# Whisper confidence below this triggers large-v3 re-transcription (if audio clip present)
WHISPER_CONFIDENCE_THRESHOLD=0.85

# Ollama base URL — configured in memory-mcp, not called directly by pipeline_worker.
# Shown here for reference: memory-mcp on Pi 4 calls Ollama on blackmagic.lan (Threadripper + Titan RTX)
OLLAMA_BASE_URL=http://blackmagic.lan:11434/v1

# Home Assistant webhook URL for probable-match notifications (optional)
# Leave blank to disable HA notifications
HA_WEBHOOK_URL=

# Speaker encoder backend
# Options: resemblyzer (default), ecapa_tdnn, titanet
# Switching encoders: restart the worker — it auto-recomputes from stored audio.
# After switching, run: curl -X POST http://blackmagic.lan:8001/recompute_embeddings
SPEAKER_ENCODER=resemblyzer

# PyTorch device for the speaker encoder (ignored for resemblyzer which is CPU-only)
# Options: cpu, cuda, cuda:0
SPEAKER_ENCODER_DEVICE=cpu

# Retain raw enrollment audio for re-embedding when switching encoders.
# Set to false to save disk space if re-recording is acceptable.
STORE_ENROLLMENT_AUDIO=true

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

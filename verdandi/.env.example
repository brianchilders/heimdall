# Verdandi Recommender Engine — copy to .env and edit

# Upstream services
OLLAMA_URL=http://blackmagic.lan:11434
MUNINN_URL=http://blackmagic.lan:8900

# Embedding model — must match MUNINN_EMBED_MODEL
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# Service
VERDANDI_PORT=8901

# Scoring weights (must sum to 1.0)
VERDANDI_W_SIM=0.60
VERDANDI_W_REC=0.25
VERDANDI_W_URG=0.15

# Filtering
VERDANDI_MIN_SCORE=0.35
VERDANDI_TOP_K=5

# Recency decay — memories older than this score 0 for recency
VERDANDI_RECENCY_DAYS=7

# Urgency window — deadlines within this many hours get a boost
VERDANDI_URGENCY_WINDOW_HOURS=2

# Logging
LOG_LEVEL=INFO

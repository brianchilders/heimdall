# room_node — copy to .env and fill in values

# Identifier for this room (used as metadata in every payload)
ROOM_NAME=kitchen

# Pipeline worker endpoint
# Full node (heimdall): localhost — room_node and pipeline_worker run on the same machine
# Capture node (additional Pi): http://heimdall.local:8001
BLACKMAGIC_URL=http://localhost:8001

# sounddevice device index for the ReSpeaker XVF3800 USB Mic Array
# Run: python -c "import sounddevice; print(sounddevice.query_devices())" to list
DEVICE_INDEX=0

# Audio sample rate — must match ReSpeaker and Whisper expectation
SAMPLE_RATE=16000

# VAD settings
VAD_THRESHOLD=0.5           # Silero VAD speech probability threshold (0.0–1.0)
VAD_MIN_SILENCE_MS=500      # Minimum silence to end an utterance
VAD_SPEECH_PAD_MS=100       # Padding added around detected speech
MAX_UTTERANCE_S=30          # Hard cap on utterance length (seconds)

# Confidence thresholds
WHISPER_CONFIDENCE_THRESHOLD=0.85
# Utterances below this threshold have audio_clip_b64 attached to payload

# Hailo-8 settings
# Note: HAILO_ENABLED=false uses faster-whisper CPU fallback (recommended for now)
# Hailo-8 supports Whisper tiny/base via hailo-whisper (not small) — see docs/room-node.md
HAILO_ENABLED=false
# Path to compiled Whisper .hef model file (tiny or base only on Hailo-8)
HAILO_WHISPER_HEF=./models/whisper_tiny.hef
# Path to compiled emotion model .hef file
HAILO_EMOTION_HEF=./models/emotion.hef
# Whisper model size for faster-whisper fallback
WHISPER_FALLBACK_MODEL=small

# HTTP retry settings
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_S=1.0
# Max payloads to buffer when pipeline worker is unreachable (oldest evicted when full)
OFFLINE_QUEUE_MAXSIZE=50

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
